"Icon"="%INSTALL_DIR%\\VideoCompressorUI.exe,0"
[HKEY_CLASSES_ROOT\SystemFileAssociations\.mov\shell\VideoCompressor\command]
@="\"%INSTALL_DIR%\\VideoCompressorUI.exe\" \"%1\""

