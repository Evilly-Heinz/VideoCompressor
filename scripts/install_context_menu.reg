Windows Registry Editor Version 5.00

; ============================================================
;  VideoCompressor — right-click context menu for video files
;
;  Option A (recommended):
;    Open VideoCompressorUI.exe and click "Register" in the
;    Explorer Integration section. The app writes this file
;    with the correct path and imports it automatically.
;
;  Option B (manual):
;    Replace every %INSTALL_DIR% below with the full path to
;    the folder that contains VideoCompressorUI.exe, then
;    double-click this file (requires administrator).
;
;  Example path: C:\\Users\\You\\Apps\\VideoCompressor
; ============================================================

; ── .mp4 ─────────────────────────────────────────────────────
[HKEY_CLASSES_ROOT\SystemFileAssociations\.mp4\shell\VideoCompressor]
@="Compress this video"
"Icon"="%INSTALL_DIR%\\VideoCompressorUI.exe,0"
[HKEY_CLASSES_ROOT\SystemFileAssociations\.mp4\shell\VideoCompressor\command]
@="\"%INSTALL_DIR%\\VideoCompressorUI.exe\" \"%1\""

