<Window x:Class="VideoCompressorUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Video Compressor"
        Width="820" Height="720"
        MinWidth="700" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBaseBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI, sans-serif"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        ResizeMode="CanResize"
        WindowStyle="None"
        MouseLeftButtonDown="TitleBar_MouseDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      CornerRadius="8"
                      GlassFrameThickness="0,0,0,1"
                      ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <Border CornerRadius="8"
            BorderBrush="{StaticResource StrokeDefaultBrush}"
            BorderThickness="1"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══ Title bar ══ -->
            <Grid Grid.Row="0" Background="{StaticResource BgLayer1Brush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="138"/>
                </Grid.ColumnDefinitions>

                <Viewbox Grid.Column="0" Width="18" Height="18"
                         HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Canvas Width="16" Height="16">
                        <Rectangle Canvas.Left="0" Canvas.Top="2" Width="16" Height="12"
                                   RadiusX="2" RadiusY="2"
                                   Stroke="{StaticResource AccentBrush}"
                                   StrokeThickness="1.2" Fill="Transparent"/>
                        <Rectangle Canvas.Left="0" Canvas.Top="2"  Width="3" Height="3" Fill="{StaticResource AccentBrush}" Opacity="0.7"/>
                        <Rectangle Canvas.Left="0" Canvas.Top="7"  Width="3" Height="3" Fill="{StaticResource AccentBrush}" Opacity="0.7"/>
                        <Rectangle Canvas.Left="0" Canvas.Top="11" Width="3" Height="3" Fill="{StaticResource AccentBrush}" Opacity="0.7"/>
                        <Rectangle Canvas.Left="13" Canvas.Top="2"  Width="3" Height="3" Fill="{StaticResource AccentBrush}" Opacity="0.7"/>
                        <Rectangle Canvas.Left="13" Canvas.Top="7"  Width="3" Height="3" Fill="{StaticResource AccentBrush}" Opacity="0.7"/>
                        <Rectangle Canvas.Left="13" Canvas.Top="11" Width="3" Height="3" Fill="{StaticResource AccentBrush}" Opacity="0.7"/>
                        <Line X1="3" Y1="2" X2="3" Y2="14" Stroke="{StaticResource AccentBrush}" StrokeThickness="0.8" Opacity="0.5"/>
                        <Line X1="13" Y1="2" X2="13" Y2="14" Stroke="{StaticResource AccentBrush}" StrokeThickness="0.8" Opacity="0.5"/>
                    </Canvas>
                </Viewbox>

                <TextBlock Grid.Column="1" Text="Video Compressor"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button x:Name="MinBtn" Width="46" Height="48" Content="&#xE921;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Background="Transparent" BorderThickness="0"
                            Click="MinBtn_Click" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#20FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="MaxBtn" Width="46" Height="48" Content="&#xE922;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Background="Transparent" BorderThickness="0"
                            Click="MaxBtn_Click" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#20FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="CloseBtn" Width="46" Height="48" Content="&#xE8BB;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Background="Transparent" BorderThickness="0"
                            Click="CloseBtn_Click" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#E81123"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Separator -->
            <Border Grid.Row="1" Background="{StaticResource StrokeDefaultBrush}"/>

            <!-- ══ Main content ══ -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>    <!-- two-column panels -->
                    <RowDefinition Height="Auto"/> <!-- bottom bar -->
                </Grid.RowDefinitions>

                <!-- ── Two-column area ── -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>   <!-- left 60% -->
                        <ColumnDefinition Width="1"/>    <!-- divider -->
                        <ColumnDefinition Width="2*"/>   <!-- right 40% -->
                    </Grid.ColumnDefinitions>

                    <!-- ════ LEFT PANEL ════ -->
                    <Grid Grid.Column="0" Margin="16,16,12,12">

                        <!-- Large drop zone (visible when queue empty) -->
                        <Border x:Name="DropZoneLarge"
                                Padding="0,48" Cursor="Hand"
                                MouseLeftButtonUp="DropZone_Click">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8B7;"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="40" HorizontalAlignment="Center"
                                           Margin="0,0,0,16"
                                           Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="Drop videos here"
                                           FontSize="16" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="or click to browse"
                                           FontSize="13" HorizontalAlignment="Center"
                                           Margin="0,0,0,14"
                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                                <TextBlock Text="MP4 · MOV · AVI · MKV · WEBM — Multiple files supported"
                                           FontSize="10" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Opacity="0.7"/>
                            </StackPanel>
                        </Border>

                        <!-- Queue area (visible when files are added) -->
                        <Grid x:Name="QueueArea" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- compact bar + header -->
                                <RowDefinition Height="*"/>     <!-- scrollable list -->
                            </Grid.RowDefinitions>

                            <!-- Compact "add more files" bar + queue header -->
                            <StackPanel Grid.Row="0">
                                <Border Height="40" Cursor="Hand" Margin="0,0,0,10"
                                        MouseLeftButtonUp="DropZone_Click">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                            <Setter Property="Padding" Value="0,0"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE948;"
                                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="Add more files…"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="QueueHeader"
                                           Text="QUEUE  (0)"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="2,0,0,8"/>
                            </StackPanel>

                            <!-- Scrollable queue list -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Queue}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,6" CornerRadius="8"
                                                    BorderThickness="1"
                                                    Padding="10,10,10,10">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background"  Value="{StaticResource BgLayer1Brush}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource StrokeDefaultBrush}"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background"  Value="{StaticResource BgLayer2Brush}"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource StrokeStrongBrush}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="48"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="32"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Thumbnail (shell thumbnail overlays icon) -->
                                                    <Border Grid.Column="0"
                                                            Width="48" Height="48"
                                                            CornerRadius="4"
                                                            Background="{StaticResource BgLayer2Brush}"
                                                            ClipToBounds="True">
                                                        <Grid>
                                                            <TextBlock Text="&#xE8B2;"
                                                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                                       FontSize="20"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                                                            <Image Source="{Binding Thumbnail}"
                                                                   Stretch="UniformToFill"/>
                                                        </Grid>
                                                    </Border>

                                                    <!-- File info + per-item progress -->
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding FileName}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding SizeMb}"
                                                                   FontSize="10" Margin="0,2,0,0"
                                                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                                                        <ProgressBar Value="{Binding Progress}"
                                                                     Style="{StaticResource FluentProgress}"
                                                                     Margin="0,6,0,0"
                                                                     Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>

                                                    <!-- Animated status badge -->
                                                    <Border x:Name="StatusBadge"
                                                            Grid.Column="4"
                                                            CornerRadius="6" Padding="10,5"
                                                            Background="{Binding StatusBackground}"
                                                            VerticalAlignment="Center"
                                                            MinWidth="74">
                                                        <TextBlock Text="{Binding Status}"
                                                                   FontSize="10" FontWeight="SemiBold"
                                                                   Foreground="{Binding StatusColor}"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>

                                                    <!-- Remove button -->
                                                    <Button Grid.Column="6"
                                                            Tag="{Binding}"
                                                            Click="RemoveFromQueue_Click"
                                                            Style="{StaticResource IconButton}"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center">
                                                        <TextBlock Text="✕"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Button>
                                                </Grid>
                                            </Border>

                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Compressing">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="CompressPulse">
                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="StatusBadge"
                                                                    Storyboard.TargetProperty="Opacity"
                                                                    From="1.0" To="0.35"
                                                                    Duration="0:0:0.75"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="CompressPulse"/>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                    </Grid>

                    <!-- Vertical divider -->
                    <Border Grid.Column="1" Background="{StaticResource StrokeDefaultBrush}"/>

                    <!-- ════ RIGHT PANEL (settings sidebar) ════ -->
                    <ScrollViewer Grid.Column="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="20,16,20,16">

                            <!-- ── QUALITY (CRF) ── -->
                            <StackPanel Margin="0,0,0,16">
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="QUALITY"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                        <TextBlock x:Name="CrfLabel" Text="28"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock Text=" CRF" FontSize="10"
                                                   Foreground="{StaticResource TextTertiaryBrush}"
                                                   VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                    </StackPanel>
                                </Grid>
                                <Slider x:Name="CrfSlider"
                                        Style="{StaticResource FluentSlider}"
                                        Minimum="18" Maximum="40" Value="28"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="CrfSlider_ValueChanged"
                                        Margin="0,0,0,4"/>
                                <Grid>
                                    <TextBlock Text="Better quality" FontSize="9"
                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                    <TextBlock Text="Smaller file" FontSize="9"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <TextBlock x:Name="CrfDescLabel"
                                           Text="Balanced"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,7,0,0"/>
                            </StackPanel>

                            <!-- ── SPEED PRESET ── -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="SPEED PRESET"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="PresetCombo"
                                          Style="{StaticResource FluentCombo}"
                                          SelectedIndex="2">
                                    <ComboBoxItem Content="ultrafast"  Tag="ultrafast"/>
                                    <ComboBoxItem Content="fast"       Tag="fast"/>
                                    <ComboBoxItem Content="medium  (recommended)" Tag="medium"/>
                                    <ComboBoxItem Content="slow"       Tag="slow"/>
                                    <ComboBoxItem Content="veryslow"   Tag="veryslow"/>
                                </ComboBox>
                                <TextBlock Text="Slower = smaller file, same quality"
                                           FontSize="9" Margin="0,4,0,0"
                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>

                            <!-- ── RESOLUTION ── -->
                            <StackPanel Margin="0,0,0,0">
                                <TextBlock Text="RESOLUTION"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="ResolutionCombo"
                                          Style="{StaticResource FluentCombo}"
                                          SelectedIndex="0"
                                          SelectionChanged="ResolutionCombo_SelectionChanged">
                                    <ComboBoxItem Content="Keep original" Tag=""/>
                                    <ComboBoxItem Content="1080p"         Tag="1080"/>
                                    <ComboBoxItem Content="720p"          Tag="720"/>
                                    <ComboBoxItem Content="480p"          Tag="480"/>
                                </ComboBox>
                                <TextBlock x:Name="SourceResLabel"
                                           Text=""
                                           FontSize="9" Margin="0,4,0,0"
                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>

                            <!-- Divider -->
                            <Border Height="1" Background="{StaticResource StrokeDefaultBrush}"
                                    Margin="0,16,0,16"/>

                            <!-- ── OUTPUT FOLDER ── -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="OUTPUT FOLDER"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="OutputFolderLabel"
                                               Grid.Column="0"
                                               Text="(same as source)"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="2" Content="Browse…"
                                            Style="{StaticResource SubtleButton}"
                                            VerticalAlignment="Center"
                                            Click="OutputFolderBtn_Click"/>
                                    <Button Grid.Column="4" Content="Reset"
                                            Style="{StaticResource SubtleButton}"
                                            VerticalAlignment="Center"
                                            Click="ResetOutputFolderBtn_Click"/>
                                </Grid>
                            </StackPanel>

                            <!-- ── OUTPUT SUFFIX ── -->
                            <StackPanel Margin="0,0,0,0">
                                <TextBlock Text="OUTPUT SUFFIX"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,0,0,6"/>
                                <TextBox x:Name="OutputSuffixBox"
                                         Text="_compressed"
                                         Style="{StaticResource FluentTextBox}"
                                         TextChanged="OutputSuffixBox_TextChanged"/>
                                <TextBlock Text="Appended to original filename before .mp4"
                                           FontSize="9" Margin="0,4,0,0"
                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>

                            <!-- Divider -->
                            <Border Height="1" Background="{StaticResource StrokeDefaultBrush}"
                                    Margin="0,16,0,16"/>

                            <!-- ── ESTIMATED OUTPUT (mini-card) ── -->
                            <Border x:Name="EstimateCard"
                                    Visibility="Collapsed"
                                    CornerRadius="6" Padding="12,10"
                                    Background="{StaticResource BgLayer2Brush}"
                                    BorderBrush="{StaticResource StrokeDefaultBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ESTIMATED OUTPUT"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               Margin="0,0,0,6"/>
                                    <WrapPanel>
                                        <TextBlock x:Name="EstimateSrcLabel"
                                                   Text="—"
                                                   FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Bottom"/>
                                        <TextBlock x:Name="EstimateArrowLabel"
                                                   Text="  →  "
                                                   FontSize="15" VerticalAlignment="Bottom"
                                                   Foreground="{StaticResource TextTertiaryBrush}"
                                                   Visibility="Collapsed"/>
                                        <TextBlock x:Name="EstimateOutLabel"
                                                   Text=""
                                                   FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   VerticalAlignment="Bottom"
                                                   Visibility="Collapsed"/>
                                        <TextBlock x:Name="EstimatePctLabel"
                                                   Text=""
                                                   FontSize="12" VerticalAlignment="Bottom"
                                                   Margin="8,0,0,1"
                                                   Foreground="{StaticResource SuccessBrush}"
                                                   Visibility="Collapsed"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Divider -->
                            <Border Height="1" Background="{StaticResource StrokeDefaultBrush}"
                                    Margin="0,16,0,16"/>

                            <!-- ── EXPLORER INTEGRATION ── -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="EXPLORER INTEGRATION"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="CtxMenuStatusLabel"
                                               Text="Add right-click &quot;Compress video&quot; to Explorer"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button x:Name="RegisterCtxBtn"
                                        Grid.Column="2"
                                        Content="Register"
                                        Style="{StaticResource SubtleButton}"
                                        VerticalAlignment="Center"
                                        Click="RegisterCtxBtn_Click"/>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>

                </Grid>

                <!-- ════ BOTTOM BAR ════ -->
                <Border Grid.Row="1"
                        Background="{StaticResource BgLayer1Brush}"
                        BorderBrush="{StaticResource StrokeDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- thin progress indicator -->
                            <RowDefinition Height="56"/>    <!-- action row -->
                        </Grid.RowDefinitions>

                        <!-- Per-file compression progress (thin accent bar) -->
                        <ProgressBar x:Name="BottomProgress"
                                     Grid.Row="0"
                                     Height="3"
                                     Style="{StaticResource FluentProgress}"
                                     Minimum="0" Maximum="100" Value="0"
                                     IsIndeterminate="False"
                                     Visibility="Collapsed"/>

                        <!-- Action row: Browse+Clear | Status | Compress -->
                        <Grid Grid.Row="1" Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button x:Name="BrowseBtn"
                                        Content="Browse file…"
                                        Style="{StaticResource SubtleButton}"
                                        Click="BrowseBtn_Click"/>
                                <Button x:Name="ClearQueueBtn"
                                        Content="Clear queue"
                                        Style="{StaticResource SubtleButton}"
                                        Margin="10,0,0,0"
                                        Visibility="Collapsed"
                                        Click="ClearQueue_Click"/>
                            </StackPanel>

                            <TextBlock x:Name="StatusLabel"
                                       Grid.Column="1"
                                       Text="Ready — drop videos here or click Browse"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>

                            <Button x:Name="CompressBtn"
                                    Grid.Column="2"
                                    Content="▶  Compress"
                                    Style="{StaticResource AccentButton}"
                                    IsEnabled="False"
                                    VerticalAlignment="Center"
                                    Click="CompressBtn_Click"/>
                        </Grid>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Border>
</Window>
