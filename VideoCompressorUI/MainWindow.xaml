<Window x:Class="VideoCompressorUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Video Compressor"
        Width="700" Height="560"
        MinWidth="620" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBaseBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI, sans-serif"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        ResizeMode="CanResize"
        WindowStyle="None"
        MouseLeftButtonDown="TitleBar_MouseDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      CornerRadius="8"
                      GlassFrameThickness="0,0,0,1"
                      ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <Border CornerRadius="8"
            BorderBrush="{StaticResource StrokeDefaultBrush}"
            BorderThickness="1"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>     <!-- custom title bar -->
                <RowDefinition Height="1"/>      <!-- separator -->
                <RowDefinition Height="*"/>      <!-- content -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════
                 Custom title bar
            ══════════════════════════════ -->
            <Grid Grid.Row="0" Background="{StaticResource BgLayer1Brush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>   <!-- icon -->
                    <ColumnDefinition/>
                    <ColumnDefinition Width="138"/>  <!-- caption buttons -->
                </Grid.ColumnDefinitions>

                <!-- App icon area -->
                <Viewbox Grid.Column="0" Width="18" Height="18"
                         HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Canvas Width="16" Height="16">
                        <Rectangle Canvas.Left="0" Canvas.Top="2" Width="16" Height="12"
                                   RadiusX="2" RadiusY="2"
                                   Stroke="{StaticResource AccentBrush}"
                                   StrokeThickness="1.2" Fill="Transparent"/>
                        <Rectangle Canvas.Left="0" Canvas.Top="2" Width="3" Height="3"
                                   Fill="{StaticResource AccentBrush}" Opacity="0.7"/>
                        <Rectangle Canvas.Left="0" Canvas.Top="7" Width="3" Height="3"
                                   Fill="{StaticResource AccentBrush}" Opacity="0.7"/>
                        <Rectangle Canvas.Left="0" Canvas.Top="11" Width="3" Height="3"
                                   Fill="{StaticResource AccentBrush}" Opacity="0.7"/>
                        <Rectangle Canvas.Left="13" Canvas.Top="2" Width="3" Height="3"
                                   Fill="{StaticResource AccentBrush}" Opacity="0.7"/>
                        <Rectangle Canvas.Left="13" Canvas.Top="7" Width="3" Height="3"
                                   Fill="{StaticResource AccentBrush}" Opacity="0.7"/>
                        <Rectangle Canvas.Left="13" Canvas.Top="11" Width="3" Height="3"
                                   Fill="{StaticResource AccentBrush}" Opacity="0.7"/>
                        <Line X1="3" Y1="2" X2="3" Y2="14"
                              Stroke="{StaticResource AccentBrush}" StrokeThickness="0.8" Opacity="0.5"/>
                        <Line X1="13" Y1="2" X2="13" Y2="14"
                              Stroke="{StaticResource AccentBrush}" StrokeThickness="0.8" Opacity="0.5"/>
                    </Canvas>
                </Viewbox>

                <!-- Title text -->
                <TextBlock Grid.Column="1"
                           Text="Video Compressor"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,0,0"/>

                <!-- Caption buttons: min / max / close -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button x:Name="MinBtn" Width="46" Height="48" Content="&#xE921;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                            FontSize="10"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Background="Transparent" BorderThickness="0"
                            Click="MinBtn_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#20FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="MaxBtn" Width="46" Height="48" Content="&#xE922;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                            FontSize="10"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Background="Transparent" BorderThickness="0"
                            Click="MaxBtn_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#20FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="CloseBtn" Width="46" Height="48" Content="&#xE8BB;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                            FontSize="10"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Background="Transparent" BorderThickness="0"
                            Click="CloseBtn_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#E81123"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Separator line -->
            <Border Grid.Row="1" Background="{StaticResource StrokeDefaultBrush}"/>

            <!-- ══════════════════════════════
                 Main content
            ══════════════════════════════ -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,20,24,24" >

                    <!-- Drop zone -->
                    <Border x:Name="DropZone"
                            Padding="0,32"
                            Margin="0,0,0,24"
                            Cursor="Hand"
                            MouseLeftButtonUp="DropZone_Click">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush"
                                                Value="{StaticResource AccentBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center" >
                            <TextBlock x:Name="DropIcon" Text="&#xE8B7;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="32" HorizontalAlignment="Center"
                                       Margin="0,0,0,16"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock x:Name="DropLabel"
                                       Text="Drop video here  or  click to browse"
                                       FontSize="14"
                                       Margin="0,0,0,12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="MP4  ·  MOV  ·  AVI  ·  MKV  ·  WMV  ·  FLV  ·  WEBM"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Settings card -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <!-- Quality (CRF) -->
                            <StackPanel Grid.Column="0"  >
                                <Grid>
                                    <TextBlock Text="QUALITY"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               />
                                    <StackPanel HorizontalAlignment="Right"
                                                Orientation="Horizontal" 
                                                VerticalAlignment="Center">
                                        <TextBlock x:Name="CrfLabel" Text="28"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock Text=" CRF" FontSize="11"
                                                   Foreground="{StaticResource TextTertiaryBrush}"
                                                   VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                    </StackPanel>
                                </Grid>
                                <Slider x:Name="CrfSlider"
                                        Style="{StaticResource FluentSlider}"
                                        Minimum="18" Maximum="40" Value="28"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="CrfSlider_ValueChanged"/>
                                <Grid>
                                    <TextBlock Text="Better quality" FontSize="10"
                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                    <TextBlock Text="Smaller file"   FontSize="10"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>

                            <!-- Preset -->
                            <StackPanel Grid.Column="2"  >
                                <TextBlock Text="SPEED PRESET"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                            />
                                <ComboBox x:Name="PresetCombo"
                                          Style="{StaticResource FluentCombo}"
                                          SelectedIndex="2">
                                    <ComboBoxItem Content="ultrafast"  Tag="ultrafast"/>
                                    <ComboBoxItem Content="fast"       Tag="fast"/>
                                    <ComboBoxItem Content="medium  (recommended)" Tag="medium"/>
                                    <ComboBoxItem Content="slow"       Tag="slow"/>
                                    <ComboBoxItem Content="veryslow"   Tag="veryslow"/>
                                </ComboBox>
                                <TextBlock Text="Slower preset = smaller file, same quality"
                                           FontSize="10"
                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Action row -->
                    <Grid >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BrowseBtn" Grid.Column="0"
                                Content="Browse file…"
                                Style="{StaticResource SubtleButton}"
                                Click="BrowseBtn_Click"/>
                        <Button x:Name="CompressBtn" Grid.Column="2"
                                Content="▶  Compress"
                                Style="{StaticResource AccentButton}"
                                IsEnabled="False"
                                Click="CompressBtn_Click"/>
                    </Grid>
                    <!-- Progress card (hidden until compressing) -->
                    <Border x:Name="ProgressPanel" Margin="0,20,0,0"
                            Style="{StaticResource Card}"
                            Visibility="Collapsed" >
                        <StackPanel >
                            <Grid>
                                <TextBlock x:Name="ProgressTitle"
                                           Text="Compressing…"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="ProgressPct"
                                           Text="0%"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar x:Name="ProgressBar"
                                         Style="{StaticResource FluentProgress}"
                                         Minimum="0" Maximum="100" Value="0"/>
                            <TextBlock x:Name="ProgressDetail"
                                       Text=""
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                    </Border>


                    <!-- Status bar -->
                    <Grid Margin="0,2,0,0">
                        <TextBlock x:Name="StatusLabel"
                                   Text="Ready — drop a video file or browse to get started"
                                   FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="SizeLabel"
                                   Text=""
                                   FontSize="11"
                                   Foreground="{StaticResource SuccessBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
