<Window x:Class="VideoCompressorUI.BatchSummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compression complete"
        Width="520"
        SizeToContent="Height"
        MaxHeight="700"
        MinHeight="280"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource BgBaseBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI, sans-serif"
        MouseLeftButtonDown="TitleBar_MouseDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      CornerRadius="8"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border CornerRadius="8"
            BorderBrush="{StaticResource StrokeDefaultBrush}"
            BorderThickness="1"
            ClipToBounds="True">

        <DockPanel>

            <!-- ── Title bar ── -->
            <Grid DockPanel.Dock="Top" Height="44"
                  Background="{StaticResource BgLayer1Brush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Compression complete"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
                <Button Grid.Column="1"
                        Width="44" Height="44"
                        Content="&#xE8BB;"
                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                        FontSize="10"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Background="Transparent" BorderThickness="0"
                        Click="CloseBtn_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Title separator -->
            <Border DockPanel.Dock="Top" Height="1"
                    Background="{StaticResource StrokeDefaultBrush}"/>

            <!-- ── Bottom action bar (docked first so it stays at bottom) ── -->
            <Border DockPanel.Dock="Bottom"
                    Background="{StaticResource BgLayer1Brush}"
                    BorderBrush="{StaticResource StrokeDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,14">
                <Grid>
                    <Button x:Name="OpenFolderBtn"
                            Content="Open output folder"
                            Style="{StaticResource SubtleButton}"
                            HorizontalAlignment="Left"
                            Click="OpenFolderBtn_Click"/>
                    <Button x:Name="DoneBtn"
                            Content="Done"
                            Style="{StaticResource AccentButton}"
                            Padding="32,0"
                            HorizontalAlignment="Right"
                            Click="CloseBtn_Click"/>
                </Grid>
            </Border>

            <!-- ── Main content ── -->
            <StackPanel Margin="20,18,20,18">

                <!-- Header card: icon + title + subtitle -->
                <Border CornerRadius="8" Padding="16,14" Margin="0,0,0,12"
                        Background="{StaticResource BgLayer1Brush}"
                        BorderBrush="{StaticResource StrokeDefaultBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="SummaryTitle"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="SummarySubtitle"
                                       FontSize="11" Margin="0,3,0,0"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       Visibility="Collapsed"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock x:Name="HeaderIcon"
                                   Grid.Column="1"
                                   FontSize="28"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol"/>
                    </Grid>
                </Border>

                <!-- Three stat cards -->
                <UniformGrid Columns="3" Margin="0,0,0,12">
                    <Border CornerRadius="8" Padding="14,12" Margin="0,0,5,0"
                            Background="{StaticResource BgLayer1Brush}"
                            BorderBrush="{StaticResource StrokeDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="StatDoneValue"
                                       FontSize="26" FontWeight="SemiBold"
                                       Foreground="{StaticResource SuccessBrush}"/>
                            <TextBlock Text="done"
                                       FontSize="10" Margin="0,2,0,0"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="StatSavedCard" CornerRadius="8" Padding="14,12" Margin="2.5,0,2.5,0"
                            Background="{StaticResource BgLayer1Brush}"
                            BorderBrush="{StaticResource StrokeDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="StatSavedValue"
                                       FontSize="26" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text="saved"
                                       FontSize="10" Margin="0,2,0,0"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="StatPctCard" CornerRadius="8" Padding="14,12" Margin="5,0,0,0"
                            Background="{StaticResource BgLayer1Brush}"
                            BorderBrush="{StaticResource StrokeDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="StatPctValue"
                                       FontSize="26" FontWeight="SemiBold"
                                       Foreground="{StaticResource SuccessBrush}"/>
                            <TextBlock Text="average reduction"
                                       FontSize="10" Margin="0,2,0,0"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- File list table -->
                <Border CornerRadius="8"
                        BorderBrush="{StaticResource StrokeDefaultBrush}"
                        BorderThickness="1"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Column headers -->
                        <Grid Grid.Row="0" Height="32"
                              Background="{StaticResource BgLayer1Brush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="94"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="FILE"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center" Margin="12,0,0,0"/>
                            <TextBlock Grid.Column="1" Text="INPUT"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="2" Text="OUTPUT"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="3" Text="SAVED"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="4" Text="STATUS"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- Header / rows separator -->
                        <Border Grid.Row="1" Background="{StaticResource StrokeDefaultBrush}"/>

                        <!-- Scrollable file rows -->
                        <ScrollViewer Grid.Row="2" MaxHeight="260"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="FileList"
                                          Background="{StaticResource BgBaseBrush}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="44">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="56"/>
                                                <ColumnDefinition Width="94"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Row separator line (top) -->
                                            <Border Grid.ColumnSpan="5" Height="1"
                                                    VerticalAlignment="Top"
                                                    Background="{StaticResource StrokeDefaultBrush}"
                                                    Opacity="0.5"/>

                                            <!-- Filename -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding FileName}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="12,0,8,0"/>

                                            <!-- Input size -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding InputSize}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,0,8,0"/>

                                            <!-- Output size -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding OutputSize}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,0,8,0"/>

                                            <!-- Savings % -->
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Savings}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{Binding SavingsForeground}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,0,8,0"/>

                                            <!-- Status badge -->
                                            <Border Grid.Column="4"
                                                    CornerRadius="6" Padding="10,4"
                                                    Background="{Binding StatusBg}"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    MinWidth="74">
                                                <TextBlock Text="{Binding Status}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{Binding StatusFg}"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

            </StackPanel>
        </DockPanel>
    </Border>
</Window>
